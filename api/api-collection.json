{
  "client": "Thunder Client",
  "collectionName": "Hearst Projects API",
  "dateExported": "2026-04-21",
  "version": "1.0",
  "folders": [
    {
      "name": "Auth",
      "requests": [
        {
          "name": "Login",
          "method": "POST",
          "url": "{{baseUrl}}/api/auth/login",
          "headers": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
          }
        },
        {
          "name": "Get Current User",
          "method": "GET",
          "url": "{{baseUrl}}/api/auth/me",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            }
          ]
        },
        {
          "name": "Register User (Admin)",
          "method": "POST",
          "url": "{{baseUrl}}/api/auth/register",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"username\": \"editor\",\n  \"email\": \"editor@hearst.app\",\n  \"password\": \"password123\",\n  \"role\": \"editor\"\n}"
          }
        },
        {
          "name": "List Users (Admin)",
          "method": "GET",
          "url": "{{baseUrl}}/api/auth/users",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            }
          ]
        }
      ]
    },
    {
      "name": "Projects",
      "requests": [
        {
          "name": "List Projects",
          "method": "GET",
          "url": "{{baseUrl}}/api/projects?page=1&limit=20",
          "headers": []
        },
        {
          "name": "List Projects (Filtered)",
          "method": "GET",
          "url": "{{baseUrl}}/api/projects?status=live&published=true",
          "headers": []
        },
        {
          "name": "Get Project by ID",
          "method": "GET",
          "url": "{{baseUrl}}/api/projects/{{projectId}}",
          "headers": []
        },
        {
          "name": "Get Project by Slug",
          "method": "GET",
          "url": "{{baseUrl}}/api/projects/slug/hub",
          "headers": []
        },
        {
          "name": "Get Statistics",
          "method": "GET",
          "url": "{{baseUrl}}/api/projects/statistics",
          "headers": []
        },
        {
          "name": "Create Project",
          "method": "POST",
          "url": "{{baseUrl}}/api/projects",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"name\": \"Test Project\",\n  \"category\": \"Frontend\",\n  \"description\": \"This is a test project for API testing\",\n  \"status\": \"coming\",\n  \"tech_stack\": [\"Next.js\", \"React\", \"TypeScript\"],\n  \"port\": 3000,\n  \"urls\": {\n    \"local\": \"http://localhost:3000\",\n    \"production\": \"https://test.hearst.app\"\n  },\n  \"location\": \"/path/to/test-project\",\n  \"features\": [\n    \"Feature 1\",\n    \"Feature 2\",\n    \"Feature 3\"\n  ],\n  \"published\": false,\n  \"order_index\": 0\n}"
          }
        },
        {
          "name": "Update Project",
          "method": "PATCH",
          "url": "{{baseUrl}}/api/projects/{{projectId}}",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"name\": \"Updated Project Name\",\n  \"description\": \"Updated description\"\n}"
          }
        },
        {
          "name": "Publish Project",
          "method": "POST",
          "url": "{{baseUrl}}/api/projects/{{projectId}}/publish",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            }
          ]
        },
        {
          "name": "Unpublish Project",
          "method": "POST",
          "url": "{{baseUrl}}/api/projects/{{projectId}}/unpublish",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            }
          ]
        },
        {
          "name": "Archive Project",
          "method": "POST",
          "url": "{{baseUrl}}/api/projects/{{projectId}}/archive",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            }
          ]
        },
        {
          "name": "Delete Project",
          "method": "DELETE",
          "url": "{{baseUrl}}/api/projects/{{projectId}}",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            }
          ]
        },
        {
          "name": "Reorder Projects",
          "method": "POST",
          "url": "{{baseUrl}}/api/projects/reorder",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"order\": [\"id1\", \"id2\", \"id3\"]\n}"
          }
        }
      ]
    },
    {
      "name": "Media",
      "requests": [
        {
          "name": "List Media by Project",
          "method": "GET",
          "url": "{{baseUrl}}/api/media?project_id={{projectId}}",
          "headers": []
        },
        {
          "name": "List Logos",
          "method": "GET",
          "url": "{{baseUrl}}/api/media?project_id={{projectId}}&type=logo",
          "headers": []
        },
        {
          "name": "Get Media by ID",
          "method": "GET",
          "url": "{{baseUrl}}/api/media/{{mediaId}}",
          "headers": []
        },
        {
          "name": "Get Statistics",
          "method": "GET",
          "url": "{{baseUrl}}/api/media/statistics",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            }
          ]
        },
        {
          "name": "Upload Media",
          "method": "POST",
          "url": "{{baseUrl}}/api/media/upload",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            }
          ],
          "body": {
            "type": "formdata",
            "formdata": [
              {
                "name": "file",
                "value": "@/path/to/image.jpg",
                "type": "file"
              },
              {
                "name": "project_id",
                "value": "{{projectId}}"
              },
              {
                "name": "type",
                "value": "logo"
              }
            ]
          }
        },
        {
          "name": "Set as Logo",
          "method": "POST",
          "url": "{{baseUrl}}/api/media/{{mediaId}}/set-as-logo",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"project_id\": \"{{projectId}}\"\n}"
          }
        },
        {
          "name": "Delete Media",
          "method": "DELETE",
          "url": "{{baseUrl}}/api/media/{{mediaId}}",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer {{token}}"
            }
          ]
        }
      ]
    },
    {
      "name": "Health",
      "requests": [
        {
          "name": "Health Check",
          "method": "GET",
          "url": "{{baseUrl}}/api/health",
          "headers": []
        }
      ]
    }
  ],
  "environments": [
    {
      "name": "Local",
      "variables": [
        {
          "name": "baseUrl",
          "value": "http://localhost:5000"
        },
        {
          "name": "token",
          "value": ""
        },
        {
          "name": "projectId",
          "value": ""
        },
        {
          "name": "mediaId",
          "value": ""
        }
      ]
    },
    {
      "name": "Production",
      "variables": [
        {
          "name": "baseUrl",
          "value": "https://api.hearst.app"
        },
        {
          "name": "token",
          "value": ""
        },
        {
          "name": "projectId",
          "value": ""
        },
        {
          "name": "mediaId",
          "value": ""
        }
      ]
    }
  ]
}
