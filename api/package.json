{
  "name": "hearst-projects-api",
  "version": "1.0.0",
  "description": "Backend API professionnel pour la gestion des projets Hearst",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "migrate": "node -r tsx/cjs src/db/migrate.ts"
  },
  "keywords": [
