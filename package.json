{
  "name": "hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run kill-ports && concurrently \"next dev -p 3000\" \"node proxy-server.js\"",
    "kill-ports": "lsof -ti:3000,4000 | xargs kill -9 2>/dev/null || true",
    "dev:next": "next dev -p 3000",
    "proxy": "node proxy-server.js",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "migrate": "tsx scripts/migrate-data.ts",
    "test:api": "bash scripts/test-api.sh"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.9",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "http-proxy": "^1.18.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
